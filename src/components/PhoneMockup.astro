---
import type { Locale } from '../config';
import { t } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const d = t(locale).mockup;
---

<div class="phone-wrap">
  <div class="phone" role="img" aria-label={d.banner}>
    <div class="phone-screen">
      <div class="chat-header">
        <div class="chat-avatar">D</div>
        <div class="chat-peer">
          <div class="name">{d.contactName}</div>
          <div class="status">{d.contactStatus}</div>
        </div>
      </div>
      <div class="chat-banner">{d.banner}</div>
      <div class="chat-body">
        {d.messages.map((m) => <div class={`bubble ${m.in ? 'in' : 'out'}`}>{m.text}</div>)}
      </div>
      <div class="chat-input">{d.inputPlaceholder}</div>
    </div>
  </div>
</div>
