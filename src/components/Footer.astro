---
import { LOCALES, type Locale } from '../config';
import { t } from '../i18n';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const d = t(locale);
const home = `/${locale}/`;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="brand" href={home}>
          <Logo />
          <span>Seklio</span>
        </a>
        <p>{d.footer.tagline}</p>
      </div>
      <div class="footer-col">
        <h3>{d.footer.product}</h3>
        <ul>
          <li><a href={`${home}#how`}>{d.nav.howItWorks}</a></li>
          <li><a href={`${home}#features`}>{d.nav.features}</a></li>
          <li><a href={`${home}#download`}>{d.nav.download}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{d.footer.legal}</h3>
        <ul>
          <li><a href={`/${locale}/faq/`}>{d.nav.faq}</a></li>
          <li><a href={`/${locale}/support/`}>{d.nav.support}</a></li>
          <li><a href={`/${locale}/privacy/`}>{d.privacyPage.title}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>{d.footer.language}</h3>
        <ul>
          {
            LOCALES.map((l) => (
              <li>
                <a href={`/${l}/${slug ? slug + '/' : ''}`} data-set-lang={l} lang={l}>
                  {d.langNames[l]}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>{d.footer.rights}</span>
      <span>sekl.io</span>
    </div>
  </div>
</footer>
