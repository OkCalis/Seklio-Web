---
import { LOCALES, type Locale } from '../config';
import { t } from '../i18n';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const d = t(locale);
const home = `/${locale}/`;
---

<header class="site-header">
  <div class="container">
    <a class="brand" href={home}>
      <Logo />
      <span>Seklio</span>
    </a>
    <nav class="main-nav" aria-label="Main">
      <a href={`${home}#how`}>{d.nav.howItWorks}</a>
      <a href={`${home}#features`}>{d.nav.features}</a>
      <a href={`/${locale}/faq/`}>{d.nav.faq}</a>
      <a href={`/${locale}/support/`}>{d.nav.support}</a>
      <div class="lang-switch" aria-label={d.footer.language}>
        {
          LOCALES.map((l) => (
            <a
              href={`/${l}/${slug ? slug + '/' : ''}`}
              data-set-lang={l}
              aria-current={l === locale ? 'true' : 'false'}
              lang={l}
            >
              {l.toUpperCase()}
            </a>
          ))
        }
      </div>
      <a class="btn btn-primary btn-sm" href={`${home}#download`}>{d.nav.download}</a>
    </nav>
  </div>
</header>
